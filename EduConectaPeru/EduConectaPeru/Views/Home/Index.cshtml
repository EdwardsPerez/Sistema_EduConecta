<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduConecta Perú</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body style="margin: 0; padding: 0; overflow: hidden;">

    <style>
        /* ========== VARIABLES Y RESET ========== */
        :root {
            --primary-color: #1976D2;
            --primary-dark: #1565C0;
            --primary-light: #E3F2FD;
            --secondary-color: #7E57C2;
            --success-color: #2E7D32;
            --warning-color: #FF9800;
            --danger-color: #D32F2F;
            --info-color: #0288D1;
            --dark-color: #1A237E;
            --light-color: #F5F7FA;
            --gray-color: #78909C;
            --white: #FFFFFF;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.08);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.12);
            --shadow-lg: 0 8px 32px rgba(0,0,0,0.16);
            --gradient-primary: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
            --gradient-secondary: linear-gradient(135deg, #7E57C2 0%, #5E35B1 100%);
            --gradient-success: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
            --gradient-warning: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
            --gradient-danger: linear-gradient(135deg, #F44336 0%, #D32F2F 100%);
            --border-radius-sm: 8px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: var(--light-color);
            overflow: hidden;
        }

        /* ========== WELCOME PAGE ========== */
        .welcome-container {
            position: fixed;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
            background: linear-gradient(135deg, #667eea 0%);
        }

        .background-pattern {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 80%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.1) 0%, transparent 50%);
        }

        .floating-shapes {
            position: absolute;
            width: 100%;
            height: 100%;
        }

        .floating-shape {
            position: absolute;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            animation: float 20s infinite linear;
        }

        .shape-1 {
            width: 300px;
            height: 300px;
            top: -150px;
            left: -150px;
        }

        .shape-2 {
            width: 200px;
            height: 200px;
            top: 20%;
            right: -100px;
            animation-delay: -5s;
        }

        .shape-3 {
            width: 150px;
            height: 150px;
            bottom: 10%;
            left: 10%;
            animation-delay: -10s;
        }

        .welcome-content {
            position: relative;
            z-index: 2;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            text-align: center;
            color: var(--white);
        }

        .logo-animation {
            animation: logoReveal 1s ease-out forwards;
            opacity: 0;
            transform: translateY(30px);
        }


        .logo-container img {
            max-width: 400px;
            height: auto;
            filter: drop-shadow(0 10px 30px rgba(0,0,0,0.3));
            transition: transform 0.5s ease;
        }

            .logo-container img:hover {
                transform: scale(1.05) rotate(-2deg);
            }

        .welcome-title {
            font-size: 3.5rem;
            font-weight: 800;
            margin: 2rem 0 1rem;
            background: linear-gradient(135deg, #ffffff 0%, #e0e0e0 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: titleReveal 1s ease-out 0.3s forwards;
            opacity: 0;
            transform: translateY(30px);
        }


        .welcome-subtitle {
            font-size: 1.25rem;
            font-weight: 300;
            margin-bottom: 3rem;
            opacity: 0;
            animation: subtitleReveal 1s ease-out 0.6s forwards;
            max-width: 600px;
            line-height: 1.6;
        }


        .btn-login {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--white);
            color: var(--primary-color);
            padding: 1.2rem 3rem;
            font-size: 1.1rem;
            font-weight: 600;
            border: none;
            border-radius: 50px;
            text-decoration: none;
            opacity: 0;
            animation: btnReveal 1s ease-out 0.9s forwards;
            transition: var(--transition);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }

            .btn-login::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
                transition: left 0.5s;
            }

            .btn-login:hover::before {
                left: 100%;
            }

            .btn-login:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(0,0,0,0.3);
                background: #f8f9fa;
            }


        /* ========== DASHBOARD LAYOUT ========== */
        .dashboard-layout {
            display: flex;
            height: 100vh;
            background: var(--light-color);
            overflow: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: var(--white);
            border-right: 1px solid rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-md);
            z-index: 10;
            transition: width 0.3s ease;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(0,0,0,0.1);
            background: var(--gradient-primary);
        }

        .sidebar-logo {
            max-width: 180px;
            height: auto;
            filter: brightness(0) invert(1);
            transition: var(--transition);
        }

        .sidebar-title {
            color: var(--white);
            font-size: 0.9rem;
            font-weight: 500;
            opacity: 0.9;
            margin-top: 0.5rem;
            letter-spacing: 1px;
        }

        .sidebar-menu {
            flex: 1;
            padding: 1.5rem 0;
            overflow-y: auto;
        }

        .menu-section {
            margin-bottom: 2rem;
        }

        .menu-section-title {
            padding: 0 1.5rem 0.75rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--gray-color);
            font-weight: 600;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 0.875rem 1.5rem;
            color: #424242;
            text-decoration: none;
            transition: var(--transition);
            position: relative;
            border-left: 4px solid transparent;
            margin: 0.25rem 0;
        }

            .menu-item:hover {
                background: var(--primary-light);
                color: var(--primary-color);
                border-left-color: var(--primary-color);
            }

            .menu-item.active {
                background: var(--primary-light);
                color: var(--primary-color);
                border-left-color: var(--primary-color);
                font-weight: 600;
            }

            .menu-item i {
                font-size: 1.25rem;
                width: 24px;
                margin-right: 1rem;
                transition: var(--transition);
            }

            .menu-item:hover i,
            .menu-item.active i {
                transform: scale(1.1);
            }

        .sidebar-user {
            padding: 1.25rem 1.5rem;
            background: var(--light-color);
            border-top: 1px solid rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--gradient-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-size: 1.5rem;
            font-weight: 600;
        }

        .user-details {
            flex: 1;
        }

        .user-name {
            font-weight: 600;
            color: #212121;
            margin-bottom: 0.25rem;
        }

        .user-role {
            font-size: 0.85rem;
            color: var(--gray-color);
            background: var(--white);
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            display: inline-block;
        }

        .btn-logout-sidebar {
            background: none;
            border: none;
            color: var(--gray-color);
            cursor: pointer;
            padding: 0.5rem;
            border-radius: var(--border-radius-sm);
            transition: var(--transition);
        }

            .btn-logout-sidebar:hover {
                background: rgba(0,0,0,0.05);
                color: var(--danger-color);
            }

        /* Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .top-header {
            background: var(--white);
            padding: 1.25rem 2rem;
            border-bottom: 1px solid rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow-sm);
        }

        .page-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1A237E;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

            .page-title::before {
                content: '';
                width: 4px;
                height: 24px;
                background: var(--primary-color);
                border-radius: 2px;
            }

        .header-date {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--gray-color);
            font-size: 0.95rem;
        }

        .content-scroll {
            flex: 1;
            overflow-y: auto;
            padding: 2rem;
            background: var(--light-color);
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--white);
            border-radius: var(--border-radius-md);
            padding: 1.75rem;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 4px;
                background: var(--gradient-primary);
            }

            .stat-card:hover {
                transform: translateY(-8px);
                box-shadow: var(--shadow-lg);
            }

        .stat-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
        }

        .stat-icon-container {
            width: 60px;
            height: 60px;
            border-radius: var(--border-radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            color: var(--white);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        }

        .stat-content {
            flex: 1;
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 800;
            color: #1A237E;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            font-size: 0.95rem;
            color: var(--gray-color);
            font-weight: 500;
        }

        .stat-trend {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            padding: 0.4rem 1rem;
            border-radius: 20px;
            margin-top: 1rem;
            font-weight: 600;
        }

        .trend-up {
            background: rgba(46, 125, 50, 0.1);
            color: var(--success-color);
        }

        .trend-down {
            background: rgba(211, 47, 47, 0.1);
            color: var(--danger-color);
        }

        .trend-neutral {
            background: rgba(120, 144, 156, 0.1);
            color: var(--gray-color);
        }

        /* Charts */
        .charts-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .chart-card {
            background: var(--white);
            border-radius: var(--border-radius-md);
            padding: 1.75rem;
            box-shadow: var(--shadow-sm);
            border: 1px solid rgba(0,0,0,0.05);
        }

        .chart-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .chart-card-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1A237E;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .chart-container {
            height: 280px;
            position: relative;
        }

        /* Quick Actions */
        .section-header {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1A237E;
            margin: 2rem 0 1.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid var(--primary-light);
        }

        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
            margin-bottom: 2rem;
        }

        .action-card {
            background: var(--white);
            border-radius: var(--border-radius-md);
            padding: 1.75rem;
            text-decoration: none;
            color: inherit;
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
            border: 1px solid rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

            .action-card:hover {
                transform: translateY(-5px);
                box-shadow: var(--shadow-md);
                border-color: var(--primary-color);
            }

        .action-icon {
            width: 64px;
            height: 64px;
            border-radius: var(--border-radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            margin-bottom: 1.25rem;
            color: var(--white);
        }

        .action-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #1A237E;
            margin-bottom: 0.5rem;
        }

        .action-description {
            font-size: 0.875rem;
            color: var(--gray-color);
            line-height: 1.5;
        }

        /* Recent Activity */
        .activity-list {
            background: var(--white);
            border-radius: var(--border-radius-md);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }

        .activity-item {
            display: flex;
            align-items: center;
            padding: 1.25rem 1.75rem;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: var(--transition);
        }

            .activity-item:hover {
                background: var(--primary-light);
            }

        .activity-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            color: var(--white);
            font-size: 1rem;
        }

        .activity-content {
            flex: 1;
        }

        .activity-text {
            font-weight: 500;
            color: #424242;
        }

        .activity-time {
            font-size: 0.85rem;
            color: var(--gray-color);
            margin-top: 0.25rem;
        }

        /* Footer */
        .dashboard-footer {
            background: var(--white);
            padding: 1.25rem 2rem;
            border-top: 1px solid rgba(0,0,0,0.1);
            text-align: center;
            color: var(--gray-color);
            font-size: 0.875rem;
        }

        /* Scrollbar Styling */
        .sidebar-menu::-webkit-scrollbar,
        .content-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar-menu::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.05);
        }

        .sidebar-menu::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.2);
            border-radius: 3px;
        }

        .content-scroll::-webkit-scrollbar-thumb {
            background: var(--primary-color);
        }

    </style>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- DASHBOARD CON SIDEBAR -->
        <div class="dashboard-layout">
            <!-- Sidebar izquierdo -->

            <!-- Contenido principal -->
            <div class="main-content">
                <!-- Contenido scrolleable -->
                <div class="content-scroll">
                    @if (User.IsInRole("Administrador") || User.IsInRole("Secretaria"))
                    {
                        <!-- Tarjetas de estadísticas -->
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">1,247</div>
                                        <div class="stat-label">Total Estudiantes</div>
                                        <div class="stat-trend trend-up">
                                            <i class="bi bi-arrow-up"></i>
                                            <span>+12.5% este mes</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-primary);">
                                        <i class="bi bi-people-fill"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">S/ 156,820</div>
                                        <div class="stat-label">Ingresos Totales</div>
                                        <div class="stat-trend trend-up">
                                            <i class="bi bi-arrow-up"></i>
                                            <span>+8.2% vs mes anterior</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-success);">
                                        <i class="bi bi-cash-stack"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">48</div>
                                        <div class="stat-label">Pagos Pendientes</div>
                                        <div class="stat-trend trend-down">
                                            <i class="bi bi-arrow-down"></i>
                                            <span>-15% esta semana</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-warning);">
                                        <i class="bi bi-clock-history"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">94%</div>
                                        <div class="stat-label">Tasa de Matrícula</div>
                                        <div class="stat-trend trend-neutral">
                                            <i class="bi bi-dash"></i>
                                            <span>Sin cambios</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-secondary);">
                                        <i class="bi bi-graph-up-arrow"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Gráficos -->
                        <div class="charts-section">
                            <div class="chart-card">
                                <div class="chart-card-header">
                                    <h3 class="chart-card-title">
                                        <i class="bi bi-bar-chart-fill"></i>
                                        Matrículas por Mes
                                    </h3>
                                </div>
                                <div class="chart-container">
                                    <canvas id="enrollmentsChart"></canvas>
                                </div>
                            </div>

                            <div class="chart-card">
                                <div class="chart-card-header">
                                    <h3 class="chart-card-title">
                                        <i class="bi bi-pie-chart-fill"></i>
                                        Distribución por Grado
                                    </h3>
                                </div>
                                <div class="chart-container">
                                    <canvas id="gradesChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Accesos Rápidos -->
                        <h3 class="section-header">Accesos Rápidos</h3>
                        <div class="quick-actions">
                            <a asp-controller="Students" asp-action="Create" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-primary);">
                                    <i class="bi bi-person-plus-fill"></i>
                                </div>
                                <h4 class="action-title">Nuevo Estudiante</h4>
                                <p class="action-description">Registrar nuevo estudiante en el sistema</p>
                            </a>

                            <a asp-controller="Payments" asp-action="Create" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-success);">
                                    <i class="bi bi-cash-coin"></i>
                                </div>
                                <h4 class="action-title">Registrar Pago</h4>
                                <p class="action-description">Registrar nuevo pago de cuota</p>
                            </a>

                            <a asp-controller="Matriculas" asp-action="Create" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-secondary);">
                                    <i class="bi bi-file-earmark-plus-fill"></i>
                                </div>
                                <h4 class="action-title">Nueva Matrícula</h4>
                                <p class="action-description">Crear nueva matrícula estudiantil</p>
                            </a>

                            <a asp-controller="Reportes" asp-action="Index" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-warning);">
                                    <i class="bi bi-graph-up-arrow"></i>
                                </div>
                                <h4 class="action-title">Ver Reportes</h4>
                                <p class="action-description">Generar reportes y estadísticas</p>
                            </a>
                        </div>

                        <!-- Actividad Reciente -->
                        <h3 class="section-header">Actividad Reciente</h3>
                        <div class="activity-list">
                            <div class="activity-item">
                                <div class="activity-icon" style="background: var(--gradient-primary);">
                                    <i class="bi bi-person-plus"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-text">Nuevo estudiante registrado - Ana López</div>
                                    <div class="activity-time">Hace 15 minutos</div>
                                </div>
                            </div>
                            <div class="activity-item">
                                <div class="activity-icon" style="background: var(--gradient-success);">
                                    <i class="bi bi-cash"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-text">Pago registrado - S/ 850.00</div>
                                    <div class="activity-time">Hace 2 horas</div>
                                </div>
                            </div>
                            <div class="activity-item">
                                <div class="activity-icon" style="background: var(--gradient-secondary);">
                                    <i class="bi bi-file-text"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-text">Reporte mensual generado</div>
                                    <div class="activity-time">Hace 5 horas</div>
                                </div>
                            </div>
                            <div class="activity-item">
                                <div class="activity-icon" style="background: var(--gradient-warning);">
                                    <i class="bi bi-bell"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-text">Recordatorio: Cuotas pendientes por vencer</div>
                                    <div class="activity-time">Hace 1 día</div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (User.IsInRole("Apoderado"))
                    {
                        <!-- Panel Apoderado -->
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">3</div>
                                        <div class="stat-label">Mis Estudiantes</div>
                                        <div class="stat-trend trend-neutral">
                                            <i class="bi bi-check-circle"></i>
                                            <span>Todos activos</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-primary);">
                                        <i class="bi bi-people-fill"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">S/ 1,240</div>
                                        <div class="stat-label">Cuotas Pendientes</div>
                                        <div class="stat-trend trend-down">
                                            <i class="bi bi-arrow-down"></i>
                                            <span>-S/ 350 este mes</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-warning);">
                                        <i class="bi bi-receipt-cutoff"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">2</div>
                                        <div class="stat-label">Próximos Eventos</div>
                                        <div class="stat-trend trend-neutral">
                                            <i class="bi bi-calendar-event"></i>
                                            <span>Esta semana</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-secondary);">
                                        <i class="bi bi-calendar-check"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-card-header">
                                    <div class="stat-content">
                                        <div class="stat-value">85%</div>
                                        <div class="stat-label">Asistencia Promedio</div>
                                        <div class="stat-trend trend-up">
                                            <i class="bi bi-arrow-up"></i>
                                            <span>+5% este mes</span>
                                        </div>
                                    </div>
                                    <div class="stat-icon-container" style="background: var(--gradient-success);">
                                        <i class="bi bi-clipboard-check"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h3 class="section-header">Acciones Rápidas</h3>
                        <div class="quick-actions">
                            <a asp-controller="ApoderadoDashboard" asp-action="MisEstudiantes" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-primary);">
                                    <i class="bi bi-people-fill"></i>
                                </div>
                                <h4 class="action-title">Ver Mis Hijos</h4>
                                <p class="action-description">Información y rendimiento académico</p>
                            </a>

                            <a asp-controller="ApoderadoDashboard" asp-action="CuotasPendientes" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-success);">
                                    <i class="bi bi-credit-card"></i>
                                </div>
                                <h4 class="action-title">Pagar Cuotas</h4>
                                <p class="action-description">Pagar cuotas pendientes en línea</p>
                            </a>

                            <a href="#" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-secondary);">
                                    <i class="bi bi-calendar-week"></i>
                                </div>
                                <h4 class="action-title">Ver Horarios</h4>
                                <p class="action-description">Horarios de clases y actividades</p>
                            </a>

                            <a href="#" class="action-card">
                                <div class="action-icon" style="background: var(--gradient-warning);">
                                    <i class="bi bi-chat-dots"></i>
                                </div>
                                <h4 class="action-title">Contactar Docente</h4>
                                <p class="action-description">Comunicarse con profesores</p>
                            </a>
                        </div>
                    }
                </div>

                <!-- Footer -->
                <footer class="dashboard-footer">
                    <p>&copy; 2024 EduConecta Perú - Sistema de Gestión Educativa | Versión 2.1.0</p>
                </footer>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Gráfico de matrículas
                const enrollmentsCtx = document.getElementById('enrollmentsChart')?.getContext('2d');
                if (enrollmentsCtx) {
                    new Chart(enrollmentsCtx, {
                        type: 'line',
                        data: {
                            labels: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'],
                            datasets: [{
                                label: 'Matrículas',
                                data: [65, 78, 85, 92, 110, 125, 145, 130, 115, 95, 80, 70],
                                borderColor: '#1976D2',
                                backgroundColor: 'rgba(25, 118, 210, 0.1)',
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: false
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: {
                                        color: 'rgba(0,0,0,0.05)'
                                    }
                                },
                                x: {
                                    grid: {
                                        color: 'rgba(0,0,0,0.05)'
                                    }
                                }
                            }
                        }
                    });
                }

                // Gráfico de distribución por grado
                const gradesCtx = document.getElementById('gradesChart')?.getContext('2d');
                if (gradesCtx) {
                    new Chart(gradesCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Inicial', 'Primaria', 'Secundaria'],
                            datasets: [{
                                data: [25, 45, 30],
                                backgroundColor: [
                                    'rgba(25, 118, 210, 0.8)',
                                    'rgba(126, 87, 194, 0.8)',
                                    'rgba(46, 125, 50, 0.8)'
                                ],
                                borderColor: [
                                    'rgba(25, 118, 210, 1)',
                                    'rgba(126, 87, 194, 1)',
                                    'rgba(46, 125, 50, 1)'
                                ],
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'bottom'
                                }
                            }
                        }
                    });
                }

                // Animación para las tarjetas de estadísticas
                const statCards = document.querySelectorAll('.stat-card');
                statCards.forEach((card, index) => {
                    card.style.animationDelay = `${index * 0.1}s`;
                    card.classList.add('animate__animated', 'animate__fadeInUp');
                });
            });
        </script>
    }
    else
    {
        <!-- PÁGINA DE BIENVENIDA PARA NO AUTENTICADOS -->
        <div class="welcome-container">
            <div class="background-pattern"></div>
            <div class="floating-shapes">
                <div class="floating-shape shape-1"></div>
                <div class="floating-shape shape-2"></div>
                <div class="floating-shape shape-3"></div>
            </div>

            <div class="welcome-content">
                <div class="logo-container">
                    <img src="/images/logo-educonecta.png" alt="EduConecta Perú Logo" class="logo-animation">
                </div>

                <h1 class="welcome-title">EduConecta Perú</h1>
                <p class="welcome-subtitle">
                    Sistema integral de gestión educativa que conecta instituciones, docentes, estudiantes y familias
                    en una plataforma moderna y eficiente para la educación del siglo XXI.
                </p>

                <a asp-controller="Account" asp-action="Login" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Iniciar Sesión en el Sistema</span>
                </a>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Animación de entrada para la página de bienvenida
        document.addEventListener('DOMContentLoaded', function() {
            if (!document.querySelector('.dashboard-layout')) {
                setTimeout(() => {
                    document.querySelector('.logo-animation')?.classList.add('animate__animated', 'animate__fadeInDown');
                    setTimeout(() => {
                        document.querySelector('.welcome-title')?.classList.add('animate__animated', 'animate__fadeInUp');
                        setTimeout(() => {
                            document.querySelector('.welcome-subtitle')?.classList.add('animate__animated', 'animate__fadeInUp');
                            setTimeout(() => {
                                document.querySelector('.btn-login')?.classList.add('animate__animated', 'animate__fadeInUp');
                            }, 200);
                        }, 200);
                    }, 300);
                }, 100);
            }
        });
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

</body>
</html>