@model EduConectaPeru.Models.Docente

@{
    Layout = null;
    var antiguedad = (DateTime.Now - Model.FechaContratacion).Days / 365.25;
    var aniosAntiguedad = (int)antiguedad;
    var mesesAntiguedad = (int)((antiguedad - aniosAntiguedad) * 12);
}

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
        border-radius: 15px 15px 0 0;
        padding: 20px 25px;
    }

    .modal-body-custom {
        padding: 30px;
    }

    .detail-section {
        margin-bottom: 25px;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 10px;
        border-left: 4px solid #1976D2;
    }

    .detail-section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #495057;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .detail-section-title i {
            color: #1976D2;
            font-size: 1.3rem;
        }

    .detail-row {
        display: flex;
        padding: 10px 0;
        border-bottom: 1px solid #dee2e6;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        font-weight: 600;
        color: #6c757d;
        min-width: 180px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .detail-value {
        color: #212529;
        flex: 1;
    }

    .badge-custom {
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .badge-success {
        background: linear-gradient(135deg, #4CAF50 0%, #45A049 100%);
        color: white;
    }

    .badge-danger {
        background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
        color: white;
    }

    .badge-info {
        background: linear-gradient(135deg, #42A5F5 0%, #2196F3 100%);
        color: white;
    }

    .btn-close-custom {
        background: #6c757d;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-close-custom:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    .info-box {
        background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
        border-left: 4px solid #2196f3;
        padding: 15px;
        border-radius: 8px;
        margin-top: 20px;
    }

    .docente-avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 15px;
    }
</style>

<div class="modal-header modal-header-custom">
    <h5 class="modal-title">
        <i class="bi bi-eye"></i> Detalles del Docente
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body modal-body-custom">
    <!-- Avatar y Nombre -->
    <div class="text-center mb-4">
        <div class="docente-avatar mx-auto">
            @Model.Nombre.Substring(0, 1)@Model.Apellido.Substring(0, 1)
        </div>
        <h4 class="mb-1">@Model.Nombre @Model.Apellido</h4>
        <p class="text-muted mb-0">
            <i class="bi bi-mortarboard"></i> @Model.Especialidad
        </p>
    </div>

    <!-- Sección: Información Personal -->
    <div class="detail-section">
        <div class="detail-section-title">
            <i class="bi bi-person-badge"></i>
            <span>Información Personal</span>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-hash"></i> ID del Docente:
            </div>
            <div class="detail-value">
                <strong>#@Model.DocenteId</strong>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-card-text"></i> DNI:
            </div>
            <div class="detail-value">
                <strong>@Model.DNI</strong>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-person"></i> Nombre Completo:
            </div>
            <div class="detail-value">
                @Model.Nombre @Model.Apellido
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-toggle-on"></i> Estado:
            </div>
            <div class="detail-value">
                @if (Model.IsActive)
                {
                    <span class="badge-custom badge-success">
                        <i class="bi bi-check-circle"></i> Activo
                    </span>
                }
                else
                {
                    <span class="badge-custom badge-danger">
                        <i class="bi bi-x-circle"></i> Inactivo
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Sección: Información Académica -->
    <div class="detail-section">
        <div class="detail-section-title">
            <i class="bi bi-mortarboard"></i>
            <span>Información Académica</span>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-book"></i> Especialidad:
            </div>
            <div class="detail-value">
                <span class="badge-custom badge-info">
                    @Model.Especialidad
                </span>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-calendar-event"></i> Fecha de Contratación:
            </div>
            <div class="detail-value">
                <strong>@Model.FechaContratacion.ToString("dddd, dd 'de' MMMM 'de' yyyy")</strong>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-hourglass-split"></i> Antigüedad:
            </div>
            <div class="detail-value">
                @if (aniosAntiguedad > 0)
                {
                    <strong>@aniosAntiguedad año@(aniosAntiguedad != 1 ? "s" : "")</strong>
                }
                @if (mesesAntiguedad > 0)
                {
                    <text> y </text>
                
                    <strong>@mesesAntiguedad mes@(mesesAntiguedad != 1 ? "es" : "")</strong>
                }
                @if (aniosAntiguedad == 0 && mesesAntiguedad == 0)
                {
                    <strong>Menos de 1 mes</strong>
                }
            </div>
        </div>
    </div>

    <!-- Sección: Información de Contacto -->
    <div class="detail-section">
        <div class="detail-section-title">
            <i class="bi bi-telephone"></i>
            <span>Información de Contacto</span>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-phone"></i> Teléfono:
            </div>
            <div class="detail-value">
                <a href="tel:@Model.Telefono" class="text-decoration-none">
                    <i class="bi bi-telephone-fill text-success"></i> @Model.Telefono
                </a>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-envelope"></i> Email:
            </div>
            <div class="detail-value">
                <a href="mailto:@Model.Email" class="text-decoration-none">
                    <i class="bi bi-envelope-fill text-primary"></i> @Model.Email
                </a>
            </div>
        </div>
    </div>

    <!-- Información adicional -->
    <div class="info-box">
        <i class="bi bi-info-circle"></i>
        <strong>Información:</strong> Este docente @(Model.IsActive ? "está activo y puede ser asignado a cursos y horarios" : "está inactivo y no puede ser asignado a nuevos cursos").
    </div>
</div>

<div class="modal-footer">
    <button type="button" class="btn btn-close-custom" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Cerrar
    </button>
</div>