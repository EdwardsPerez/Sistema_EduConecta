@model EduConectaPeru.Models.GradoSeccion

@{
    Layout = null;
}

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
        border-radius: 15px 15px 0 0;
        padding: 20px 25px;
    }

    .modal-body-custom {
        padding: 30px;
    }

    .detail-section {
        margin-bottom: 25px;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 10px;
        border-left: 4px solid #1976D2;
    }

    .detail-section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #495057;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .detail-section-title i {
            color: #1976D2;
            font-size: 1.3rem;
        }

    .detail-row {
        display: flex;
        padding: 10px 0;
        border-bottom: 1px solid #dee2e6;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        font-weight: 600;
        color: #6c757d;
        min-width: 180px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .detail-value {
        color: #212529;
        flex: 1;
    }

    .badge-custom {
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .badge-success {
        background: linear-gradient(135deg, #4CAF50 0%, #45A049 100%);
        color: white;
    }

    .badge-danger {
        background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
        color: white;
    }

    .badge-info {
        background: linear-gradient(135deg, #42A5F5 0%, #2196F3 100%);
        color: white;
    }

    .badge-warning {
        background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
        color: white;
    }

    .btn-close-custom {
        background: #6c757d;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-close-custom:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    .info-box {
        background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
        border-left: 4px solid #2196f3;
        padding: 15px;
        border-radius: 8px;
        margin-top: 20px;
    }

    .grado-header {
        text-align: center;
        padding: 25px;
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        border-radius: 10px;
        color: white;
        margin-bottom: 25px;
    }

        .grado-header h3 {
            margin: 0;
            font-weight: 700;
        }

        .grado-header p {
            margin: 5px 0 0 0;
            opacity: 0.9;
        }

    .capacidad-indicator {
        width: 100%;
        height: 30px;
        background: #e9ecef;
        border-radius: 15px;
        overflow: hidden;
        position: relative;
    }

    .capacidad-bar {
        height: 100%;
        background: linear-gradient(135deg, #4CAF50 0%, #45A049 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.85rem;
        transition: width 0.3s ease;
    }
</style>

<div class="modal-header modal-header-custom">
    <h5 class="modal-title">
        <i class="bi bi-eye"></i> Detalles del Grado/Sección
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body modal-body-custom">
    <!-- Header del Grado -->
    <div class="grado-header">
        <h3>@Model.Grado - Sección @Model.Seccion</h3>
        <p>Año Escolar @Model.AnioEscolar</p>
    </div>

    <!-- Sección: Información General -->
    <div class="detail-section">
        <div class="detail-section-title">
            <i class="bi bi-info-circle"></i>
            <span>Información General</span>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-hash"></i> ID:
            </div>
            <div class="detail-value">
                <strong>#@Model.GradoSeccionId</strong>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-mortarboard"></i> Grado:
            </div>
            <div class="detail-value">
                <span class="badge-custom badge-info">
                    @Model.Grado
                </span>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-grid-3x3-gap"></i> Sección:
            </div>
            <div class="detail-value">
                <span class="badge-custom badge-warning">
                    Sección @Model.Seccion
                </span>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-calendar"></i> Año Escolar:
            </div>
            <div class="detail-value">
                <strong>@Model.AnioEscolar</strong>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-toggle-on"></i> Estado:
            </div>
            <div class="detail-value">
                @if (Model.IsActive)
                {
                    <span class="badge-custom badge-success">
                        <i class="bi bi-check-circle"></i> Activo
                    </span>
                }
                else
                {
                    <span class="badge-custom badge-danger">
                        <i class="bi bi-x-circle"></i> Inactivo
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Sección: Capacidad -->
    <div class="detail-section">
        <div class="detail-section-title">
            <i class="bi bi-people"></i>
            <span>Capacidad y Disponibilidad</span>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-person-fill"></i> Capacidad Máxima:
            </div>
            <div class="detail-value">
                <strong>@Model.Capacidad estudiantes</strong>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">
                <i class="bi bi-bar-chart"></i> Indicador de Capacidad:
            </div>
            <div class="detail-value">
                <div class="capacidad-indicator">
                    <div class="capacidad-bar" style="width: 100%;">
                        @Model.Capacidad estudiantes disponibles
                    </div>
                </div>
                <small class="text-muted mt-1 d-block">
                    @if (Model.Capacidad >= 30)
                    {
                        <text><i class="bi bi-check-circle text-success"></i> Capacidad alta</text>
                    }
                    else if (Model.Capacidad >= 20)
                    {
                        <text><i class="bi bi-exclamation-triangle text-warning"></i> Capacidad media</text>
                    }
                    else
                    {
                        <text><i class="bi bi-x-circle text-danger"></i> Capacidad baja</text>
                    }
                </small>
            </div>
        </div>
    </div>

    <!-- Información adicional -->
    <div class="info-box">
        <i class="bi bi-info-circle"></i>
        <strong>Información:</strong> Este grado/sección @(Model.IsActive ? "está activo y puede recibir matrículas de estudiantes" : "está inactivo y no acepta nuevas matrículas").
        La capacidad máxima está configurada para @Model.Capacidad estudiantes.
    </div>
</div>

<div class="modal-footer">
    <button type="button" class="btn btn-close-custom" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Cerrar
    </button>
</div>