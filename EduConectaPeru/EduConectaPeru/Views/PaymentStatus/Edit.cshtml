@model EduConectaPeru.Models.PaymentStatus

@{
    Layout = null;
}

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #42A5F5 0%, #2196F3 100%);
        color: white;
        border-radius: 15px 15px 0 0;
        padding: 20px 25px;
    }

    .modal-body-custom {
        padding: 30px;
    }

    .form-section {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f1f3f5;
    }

        .form-section:last-child {
            border-bottom: none;
        }

    .form-section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #495057;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .form-section-title i {
            color: #2196F3;
            font-size: 1.3rem;
        }

    .form-label-custom {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    .form-control-custom {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            border-color: #2196F3;
            box-shadow: 0 0 0 0.2rem rgba(33, 150, 243, 0.15);
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    .btn-update {
        background: linear-gradient(135deg, #42A5F5 0%, #2196F3 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(33, 150, 243, 0.4);
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(33, 150, 243, 0.6);
            color: white;
        }

    .text-danger {
        font-size: 0.875rem;
        margin-top: 5px;
    }

    .info-box {
        background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
        border-left: 4px solid #2196f3;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
</style>

<div class="modal-header modal-header-custom">
    <h5 class="modal-title">
        <i class="bi bi-pencil-square"></i> Editar Estado de Pago
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

<form id="editForm" asp-action="Edit" method="post">
    <div class="modal-body modal-body-custom">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="StatusId" />

        <div class="info-box">
            <i class="bi bi-info-circle"></i>
            <strong>Editando Estado:</strong> @Model.StatusName
        </div>

        <!-- Sección: Información del Estado -->
        <div class="form-section">
            <div class="form-section-title">
                <i class="bi bi-tag"></i>
                <span>Información del Estado</span>
            </div>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="StatusName" class="form-label-custom">
                        <i class="bi bi-card-heading"></i> Nombre del Estado
                    </label>
                    <input asp-for="StatusName" class="form-control form-control-custom" />
                    <span asp-validation-for="StatusName" class="text-danger"></span>
                    <small class="text-muted">
                        <i class="bi bi-lightbulb"></i> Ejemplos comunes: Pendiente, Pagado, Cancelado, En Proceso, Rechazado
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Cancelar
        </button>
        <button type="submit" class="btn btn-update">
            <i class="bi bi-check-circle"></i> Actualizar Estado
        </button>
    </div>
</form>

<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

<script>
    $(document).ready(function () {
        $('#editForm').on('submit', function (e) {
            e.preventDefault();

            if (!$(this).valid()) {
                return false;
            }

            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                data: $(this).serialize(),
                success: function () {
                    $('#editModal').modal('hide');
                    location.reload();
                },
                error: function (xhr) {
                    alert('Error al actualizar: ' + (xhr.responseText || 'Error desconocido'));
                }
            });
        });
    });
</script>