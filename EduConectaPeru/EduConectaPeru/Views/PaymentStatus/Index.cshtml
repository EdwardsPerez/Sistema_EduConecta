@model IEnumerable<EduConectaPeru.Models.PaymentStatus>

@{
    ViewData["Title"] = "Estados de Pago";
    var totalEstados = Model?.Count() ?? 0;
}

<style>
    .stats-card {
        border-radius: 15px;
        padding: 25px;
        color: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        border: none;
    }

        .stats-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

        .stats-card h3 {
            font-size: 2.5rem;
            font-weight: 700;
            margin: 10px 0;
        }

        .stats-card p {
            margin: 0;
            opacity: 0.9;
            font-size: 0.95rem;
        }

    .gradient-primary {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
    }

    .table-modern {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

        .table-modern thead {
            background: #f8f9fa;
            position: sticky;
            top: 0;
            z-index: 10;
        }

            .table-modern thead th {
                border: none;
                padding: 15px;
                font-weight: 600;
                color: #495057;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .table-modern tbody td {
            padding: 15px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f3f5;
        }

        .table-modern tbody tr:hover {
            background-color: #f8f9fa;
        }

    .btn-action {
        width: 32px;
        height: 32px;
        padding: 0;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        transition: all 0.3s ease;
        margin: 0 2px;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

    .btn-view {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
    }

    .btn-edit {
        background: linear-gradient(135deg, #42A5F5 0%, #2196F3 100%);
        color: white;
    }

    .btn-delete {
        background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
        color: white;
    }

    .btn-primary-custom {
        background: #fff;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(25, 118, 210, 0.4);
    }

        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(25, 118, 210, 0.6);
        }

    .modal-content {
        border-radius: 15px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }

    .page-header {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        border-radius: 15px;
        padding: 30px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 4px 15px rgba(25, 118, 210, 0.3);
    }

    .status-badge {
        padding: 8px 16px;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .status-pendiente {
        background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
        color: white;
    }

    .status-pagado {
        background: linear-gradient(135deg, #4CAF50 0%, #45A049 100%);
        color: white;
    }

    .status-cancelado {
        background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
        color: white;
    }

    .status-pending {
        background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
        color: white;
    }

    .status-paid {
        background: linear-gradient(135deg, #4CAF50 0%, #45A049 100%);
        color: white;
    }

    .status-cancelled {
        background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
        color: white;
    }
</style>

<div class="container-fluid py-4">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1"><i class="bi bi-list-check"></i> Estados de Pago</h2>
            </div>
            <button type="button" class="btn btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createModal">
                <i class="bi bi-plus-circle"></i> Nuevo Estado
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-12">
            <div class="stats-card gradient-primary">
                <i class="bi bi-list-ul" style="font-size: 2rem; opacity: 0.8;"></i>
                <h3>@totalEstados</h3>
                <p>Total Estados de Pago</p>
            </div>
        </div>
    </div>

    <div class="table-modern">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th><i class="bi bi-hash"></i> ID</th>
                    <th><i class="bi bi-tag"></i> Nombre del Estado</th>
                    <th><i class="bi bi-palette"></i> Vista Previa</th>
                    <th class="text-center"><i class="bi bi-gear"></i> Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var estado in Model)
                    {
                        <tr>
                            <td><strong>#@estado.StatusId</strong></td>
                            <td><strong>@estado.StatusName</strong></td>
                            <td>
                                <span class="status-badge status-@(estado.StatusName.ToLower().Replace(" ", "-"))">
                                    <i class="bi bi-circle-fill"></i> @estado.StatusName
                                </span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-action btn-view" onclick="loadDetails(@estado.StatusId)" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="btn btn-action btn-edit" onclick="loadEdit(@estado.StatusId)" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-action btn-delete" onclick="loadDelete(@estado.StatusId)" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #dee2e6;"></i>
                            <p class="text-muted mt-3">No hay estados de pago registrados</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Create -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="createModalContent">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Edit -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="editModalContent">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Details -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="detailsModalContent">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" id="deleteModalContent">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Cargar modal de creación
        $('#createModal').on('show.bs.modal', function () {
            $.get('@Url.Action("Create", "PaymentStatus")', function (data) {
                $('#createModalContent').html(data);
            });
        });

        // Cargar modal de edición
        function loadEdit(id) {
            $.get('@Url.Action("Edit", "PaymentStatus")/' + id, function (data) {
                $('#editModalContent').html(data);
                $('#editModal').modal('show');
            });
        }

        // Cargar modal de detalles
        function loadDetails(id) {
            $.get('@Url.Action("Details", "PaymentStatus")/' + id, function (data) {
                $('#detailsModalContent').html(data);
                $('#detailsModal').modal('show');
            });
        }

        // Cargar modal de eliminación
        function loadDelete(id) {
            $.get('@Url.Action("Delete", "PaymentStatus")/' + id, function (data) {
                $('#deleteModalContent').html(data);
                $('#deleteModal').modal('show');
            });
        }
    </script>
}