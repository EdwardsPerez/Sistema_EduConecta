@model EduConectaPeru.Models.PaymentType
@{ Layout = null; }

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
        border: none;
        padding: 20px 30px;
        border-radius: 15px 15px 0 0;
    }
    .modal-header-custom h5 { margin: 0; font-weight: 600; font-size: 1.3rem; }
    .modal-header-custom .btn-close { filter: brightness(0) invert(1); }
    .detail-row { padding: 15px; border-bottom: 1px solid #f1f3f5; display: flex; align-items: center; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { font-weight: 600; color: #495057; min-width: 120px; }
    .badge-custom { padding: 8px 16px; border-radius: 20px; font-weight: 500; }
    .badge-active-custom { background: linear-gradient(135deg, #4CAF50 0%, #45A049 100%); color: white; }
</style>

<div class="modal-header-custom">
    <h5><i class="bi bi-info-circle"></i> Detalles Tipo de Pago #@Model.PaymentTypeId</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body p-0">
    <div class="detail-row">
        <div class="detail-label">ID:</div>
        <div><strong>#@Model.PaymentTypeId</strong></div>
    </div>
    <div class="detail-row">
        <div class="detail-label">Nombre:</div>
        <div>@Model.TypeName</div>
    </div>
    <div class="detail-row">
        <div class="detail-label">Estado:</div>
        <div>
            @if (Model.IsActive)
            {
                <span class="badge-custom badge-active-custom"><i class="bi bi-check-circle"></i> Activo</span>
            }
        </div>
    </div>
</div>

<div class="modal-footer border-0 px-4 pb-4">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
</div>
