@model EduConectaPeru.Models.PaymentType
@{ Layout = null; }

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
        border: none;
        padding: 20px 30px;
        border-radius: 15px 15px 0 0;
    }
    .modal-header-custom h5 { margin: 0; font-weight: 600; font-size: 1.3rem; }
    .modal-header-custom .btn-close { filter: brightness(0) invert(1); }
    .form-label-custom { font-weight: 600; color: #495057; margin-bottom: 8px; }
    .form-control-custom { border: 2px solid #e0e0e0; border-radius: 8px; padding: 10px 15px; }
    .btn-submit-custom { background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%); border: none; padding: 12px 30px; border-radius: 8px; font-weight: 600; color: white; }
    .btn-cancel-custom { background: #6c757d; border: none; padding: 12px 30px; border-radius: 8px; font-weight: 600; color: white; }
</style>

<form method="post" action="@Url.Action("Create")" id="formCreate">
    @Html.AntiForgeryToken()
    
    <div class="modal-header-custom">
        <h5><i class="bi bi-plus-circle"></i> Nuevo Tipo de Pago</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    
    <div class="modal-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label class="form-label-custom">Nombre del Tipo *</label>
            <input asp-for="TypeName" class="form-control form-control-custom" placeholder="Ej: Efectivo, Transferencia, Tarjeta" />
            <span asp-validation-for="TypeName" class="text-danger small"></span>
        </div>
    </div>

    <div class="modal-footer border-0 px-4 pb-4">
        <button type="button" class="btn btn-cancel-custom" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-submit-custom">Guardar</button>
    </div>
</form>

<script>
     $('#formCreate').off('submit').on('submit', function (e) {
         e.preventDefault();
         var $form = $(this);

         $.ajax({
             url: $form.attr('action'),
             type: 'POST',
             data: $form.serialize(),
             success: function (response) {
                 // Si el controlador devolvió Json({ success = true })
                 if (response.success) {
                     $('#createModal').modal('hide');
                     // Forzar recarga inmediata
                     window.location.href = '@Url.Action("Index")';
                 } else {
                     // Si devolvió algo inesperado, recargar igual
                     location.reload();
                 }
             },
             error: function (xhr) {
                 // Si hay errores de validación (BadRequest), reemplaza el contenido del modal
                 $('#createModalContent').html(xhr.responseText);
             }
         });
     });
</script>

