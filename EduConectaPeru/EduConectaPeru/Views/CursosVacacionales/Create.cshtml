@model EduConectaPeru.Models.CursoVacacional

@{
    Layout = null;
}

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 15px 15px 0 0;
        padding: 20px 25px;
    }

    .modal-body-custom {
        padding: 30px;
    }

    .form-section {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f1f3f5;
    }

        .form-section:last-child {
            border-bottom: none;
        }

    .form-section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #495057;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .form-section-title i {
            color: #667eea;
            font-size: 1.3rem;
        }

    .form-label-custom {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    .form-control-custom {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    .btn-save {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
            color: white;
        }

    .text-danger {
        font-size: 0.875rem;
        margin-top: 5px;
    }
</style>

<div class="modal-header modal-header-custom">
    <h5 class="modal-title">
        <i class="bi bi-plus-circle"></i> Nuevo Curso Vacacional
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

<form id="createForm" asp-action="Create" method="post">
    <div class="modal-body modal-body-custom">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Sección: Información General -->
        <div class="form-section">
            <div class="form-section-title">
                <i class="bi bi-info-circle"></i>
                <span>Información General</span>
            </div>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="NombreCurso" class="form-label-custom">
                        <i class="bi bi-bookmark"></i> Nombre del Curso
                    </label>
                    <input asp-for="NombreCurso" class="form-control form-control-custom" placeholder="Ej: Curso de Verano 2025 - Natación" />
                    <span asp-validation-for="NombreCurso" class="text-danger"></span>
                </div>
                <div class="col-md-12 mb-3">
                    <label asp-for="Descripcion" class="form-label-custom">
                        <i class="bi bi-text-left"></i> Descripción
                    </label>
                    <textarea asp-for="Descripcion" class="form-control form-control-custom" rows="3" placeholder="Descripción detallada del curso"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Sección: Fechas -->
        <div class="form-section">
            <div class="form-section-title">
                <i class="bi bi-calendar-range"></i>
                <span>Fechas del Curso</span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FechaInicio" class="form-label-custom">
                        <i class="bi bi-calendar-event"></i> Fecha de Inicio
                    </label>
                    <input asp-for="FechaInicio" type="date" class="form-control form-control-custom" />
                    <span asp-validation-for="FechaInicio" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="FechaFin" class="form-label-custom">
                        <i class="bi bi-calendar-check"></i> Fecha de Fin
                    </label>
                    <input asp-for="FechaFin" type="date" class="form-control form-control-custom" />
                    <span asp-validation-for="FechaFin" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Sección: Costos y Capacidad -->
        <div class="form-section">
            <div class="form-section-title">
                <i class="bi bi-cash-stack"></i>
                <span>Costos y Capacidad</span>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Costo" class="form-label-custom">
                        <i class="bi bi-cash"></i> Costo del Curso (S/)
                    </label>
                    <input asp-for="Costo" type="number" step="0.01" class="form-control form-control-custom" placeholder="0.00" />
                    <span asp-validation-for="Costo" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="CapacidadMaxima" class="form-label-custom">
                        <i class="bi bi-people"></i> Capacidad Máxima
                    </label>
                    <input asp-for="CapacidadMaxima" type="number" class="form-control form-control-custom" placeholder="30" />
                    <span asp-validation-for="CapacidadMaxima" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="CuposDisponibles" class="form-label-custom">
                        <i class="bi bi-check2-square"></i> Cupos Disponibles
                    </label>
                    <input asp-for="CuposDisponibles" type="number" class="form-control form-control-custom" placeholder="30" />
                    <span asp-validation-for="CuposDisponibles" class="text-danger"></span>
                </div>
            </div>
        </div>

        <input type="hidden" asp-for="IsActive" value="true" />
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Cancelar
        </button>
        <button type="submit" class="btn btn-save">
            <i class="bi bi-check-circle"></i> Guardar Curso
        </button>
    </div>
</form>

<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

<script>
    $(document).ready(function () {
        $('#createForm').on('submit', function (e) {
            e.preventDefault();

            if (!$(this).valid()) {
                return false;
            }

            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                data: $(this).serialize(),
                success: function () {
                    $('#createModal').modal('hide');
                    location.reload();
                },
                error: function (xhr) {
                    alert('Error al guardar: ' + (xhr.responseText || 'Error desconocido'));
                }
            });
        });
    });
</script>