@model EduConectaPeru.Models.Quota
@{
    Layout = null;
}

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
        border: none;
        padding: 20px 30px;
        border-radius: 15px 15px 0 0;
    }

        .modal-header-custom h5 {
            margin: 0;
            font-weight: 600;
            font-size: 1.3rem;
        }

        .modal-header-custom .btn-close {
            filter: brightness(0) invert(1);
        }

    .detail-row {
        padding: 15px;
        border-bottom: 1px solid #f1f3f5;
        display: flex;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        font-weight: 600;
        color: #495057;
        min-width: 180px;
    }

    .badge-custom {
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 500;
    }

    .badge-pagado {
        background: linear-gradient(135deg, #4CAF50 0%, #45A049 100%);
        color: white;
    }

    .badge-pendiente {
        background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
        color: white;
    }

    .badge-vencido {
        background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
        color: white;
    }
</style>

<div class="modal-header-custom">
    <h5><i class="bi bi-info-circle"></i> Detalles Cuota #@Model.QuotaId</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body p-0">
    <div class="detail-row">
        <div class="detail-label">ID Cuota:</div>
        <div><strong>#@Model.QuotaId</strong></div>
    </div>
    <div class="detail-row">
        <div class="detail-label">Estudiante:</div>
        <div>@Model.Student?.NombreCompleto</div>
    </div>
    <div class="detail-row">
        <div class="detail-label">Periodo:</div>
        <div>@Model.Mes @Model.Anio</div>
    </div>
    <div class="detail-row">
        <div class="detail-label">Monto:</div>
        <div><strong class="text-primary">S/ @Model.Monto.ToString("N2")</strong></div>
    </div>
    <div class="detail-row">
        <div class="detail-label">Fecha Vencimiento:</div>
        <div>@Model.FechaVencimiento.ToString("dd/MM/yyyy")</div>
    </div>
    <div class="detail-row">
        <div class="detail-label">Estado de Pago:</div>
        <div>
            @{
                var estadoNombre = Model.PaymentStatus?.StatusName ?? "Pendiente";
            }
            @if (estadoNombre == "Pagado")
            {
                <span class="badge-custom badge-pagado"><i class="bi bi-check-circle"></i> Pagado</span>
            }
            else if (estadoNombre == "Vencido")
            {
                <span class="badge-custom badge-vencido"><i class="bi bi-exclamation-triangle"></i> Vencido</span>
            }
            else
            {
                <span class="badge-custom badge-pendiente"><i class="bi bi-clock"></i> Pendiente</span>
            }
        </div>
    </div>
    @if (Model.Matricula != null)
    {
        <div class="detail-row">
            <div class="detail-label">Matrícula:</div>
            <div>#@Model.MatriculaId - Año @Model.Matricula.AnioEscolar</div>
        </div>
    }
</div>

<div class="modal-footer border-0 px-4 pb-4">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
</div>
