@model EduConectaPeru.Models.QuotaCursoVacacional

@{
    Layout = null;
    var inscripciones = ViewBag.Inscripciones as List<EduConectaPeru.Models.InscripcionCursoVacacional>;
    var estudiantes = ViewBag.Estudiantes as List<EduConectaPeru.Models.Student>;
    var estadosPago = ViewBag.EstadosPago as List<EduConectaPeru.Models.PaymentStatus>;
}

<style>
    .form-section {
        margin-bottom: 1.5rem;
    }

    .form-section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-section-title i {
            color: #f39c12;
        }

    .form-label-modal {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.9rem;
    }

    .form-control-modal,
    .form-select-modal {
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 0.6rem 0.9rem;
        font-size: 0.9rem;
        width: 100%;
        transition: all 0.3s ease;
    }

        .form-control-modal:focus,
        .form-select-modal:focus {
            border-color: #f39c12;
            box-shadow: 0 0 0 0.2rem rgba(243, 156, 18, 0.15);
            outline: none;
        }

    .text-danger-modal {
        color: #e74c3c;
        font-size: 0.85rem;
        margin-top: 0.25rem;
        display: block;
    }

    .form-text-modal {
        font-size: 0.8rem;
        color: #7f8c8d;
        margin-top: 0.25rem;
        display: block;
    }

    .alert-info-modal {
        background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
        border: none;
        border-radius: 8px;
        color: #0c5460;
        padding: 0.85rem 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: start;
        gap: 0.75rem;
        font-size: 0.9rem;
    }

        .alert-info-modal i {
            font-size: 1.2rem;
            margin-top: 0.1rem;
        }

    .btn-update-modal {
        background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        border: none;
        padding: 0.65rem 1.75rem;
        border-radius: 6px;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 3px 10px rgba(243, 156, 18, 0.3);
    }

        .btn-update-modal:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(243, 156, 18, 0.4);
        }

    .btn-cancel-modal {
        background: #95a5a6;
        border: none;
        padding: 0.65rem 1.75rem;
        border-radius: 6px;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-cancel-modal:hover {
            background: #7f8c8d;
        }
</style>

<form asp-action="Edit" method="post" id="editCuotaForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="QuotaVacacionalId" />
    <input type="hidden" asp-for="IsActive" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <!-- Nota informativa -->
    <div class="alert-info-modal">
        <i class="bi bi-info-circle-fill"></i>
        <div>
            <strong>Nota:</strong> El estado de la cuota se gestiona desde la lista principal mediante los botones de desactivar/reactivar.
        </div>
    </div>

    <!-- Información de la Inscripción -->
    <div class="form-section">
        <div class="form-section-title">
            <i class="bi bi-journal-check"></i>
            Información de la Inscripción
        </div>

        <div class="mb-3">
            <label asp-for="InscripcionId" class="form-label-modal">Inscripción *</label>
            <select asp-for="InscripcionId" class="form-select-modal">
                <option value="">-- Seleccione una inscripción --</option>
                @if (inscripciones != null)
                {
                    @foreach (var inscripcion in inscripciones)
                    {
                        <option value="@inscripcion.InscripcionId">
                            @inscripcion.CursoVacacional?.NombreCurso - @inscripcion.Student?.NombreCompleto
                        </option>
                    }
                }
            </select>
            <span asp-validation-for="InscripcionId" class="text-danger-modal"></span>
        </div>

        <div class="mb-3">
            <label asp-for="StudentId" class="form-label-modal">Estudiante *</label>
            <select asp-for="StudentId" class="form-select-modal">
                <option value="">-- Seleccione un estudiante --</option>
                @if (estudiantes != null)
                {
                    @foreach (var estudiante in estudiantes)
                    {
                        <option value="@estudiante.StudentId">
                            @estudiante.NombreCompleto - DNI: @estudiante.DNI
                        </option>
                    }
                }
            </select>
            <span asp-validation-for="StudentId" class="text-danger-modal"></span>
        </div>
    </div>

    <!-- Período -->
    <div class="form-section">
        <div class="form-section-title">
            <i class="bi bi-calendar-month"></i>
            Período de la Cuota
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Mes" class="form-label-modal">Mes *</label>
                <select asp-for="Mes" class="form-select-modal">
                    <option value="">-- Seleccione mes --</option>
                    <option value="Enero">Enero</option>
                    <option value="Febrero">Febrero</option>
                    <option value="Marzo">Marzo</option>
                    <option value="Abril">Abril</option>
                    <option value="Mayo">Mayo</option>
                    <option value="Junio">Junio</option>
                    <option value="Julio">Julio</option>
                    <option value="Agosto">Agosto</option>
                    <option value="Septiembre">Septiembre</option>
                    <option value="Octubre">Octubre</option>
                    <option value="Noviembre">Noviembre</option>
                    <option value="Diciembre">Diciembre</option>
                </select>
                <span asp-validation-for="Mes" class="text-danger-modal"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Anio" class="form-label-modal">Año *</label>
                <input asp-for="Anio" class="form-control-modal" type="number" min="2024" max="2030" />
                <span asp-validation-for="Anio" class="text-danger-modal"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="FechaVencimiento" class="form-label-modal">Fecha Vencimiento *</label>
            <input asp-for="FechaVencimiento" class="form-control-modal" type="date" />
            <span asp-validation-for="FechaVencimiento" class="text-danger-modal"></span>
        </div>
    </div>

    <!-- Información de Pago -->
    <div class="form-section">
        <div class="form-section-title">
            <i class="bi bi-cash-coin"></i>
            Información de Pago
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Monto" class="form-label-modal">Monto *</label>
                <div class="input-group">
                    <span class="input-group-text">S/</span>
                    <input asp-for="Monto" class="form-control-modal" type="number" step="0.01" min="0" placeholder="0.00" />
                </div>
                <span asp-validation-for="Monto" class="text-danger-modal"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="PaymentStatusId" class="form-label-modal">Estado de Pago *</label>
                <select asp-for="PaymentStatusId" class="form-select-modal">
                    <option value="">-- Seleccione estado --</option>
                    @if (estadosPago != null)
                    {
                        @foreach (var estado in estadosPago)
                        {
                            <option value="@estado.StatusId">@estado.StatusName</option>
                        }
                    }
                </select>
                <span asp-validation-for="PaymentStatusId" class="text-danger-modal"></span>
            </div>
        </div>
    </div>

    <!-- Botones -->
    <div class="modal-footer">
        <button type="button" class="btn-cancel-modal" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Cancelar
        </button>
        <button type="submit" class="btn-update-modal">
            <i class="bi bi-save"></i> Actualizar Cuota
        </button>
    </div>
</form>

<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script>
    $('#editCuotaForm').on('submit', function(e) {
        e.preventDefault();

        if (!$(this).valid()) {
            return false;
        }

        $.ajax({
            url: $(this).attr('action'),
            type: 'POST',
            data: $(this).serialize(),
            success: function(result) {
                $('#editCuotaModal').modal('hide');
                location.reload();
            },
            error: function(xhr) {
                alert('Error al actualizar la cuota. Intente nuevamente.');
            }
        });
    });
</script>