@model EduConectaPeru.Models.QuotaCursoVacacional

@{
    Layout = null;
    var diasVencimiento = (Model.FechaVencimiento - DateTime.Today).Days;
}

<style>
    .details-section {
        margin-bottom: 1.5rem;
    }

    .details-section-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .details-section-title i {
            color: #3498db;
            font-size: 1.15rem;
        }

    .detail-row {
        display: flex;
        padding: 0.75rem 0;
        border-bottom: 1px solid #f1f3f5;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        font-weight: 600;
        color: #7f8c8d;
        min-width: 140px;
        font-size: 0.9rem;
    }

    .detail-value {
        color: #2c3e50;
        font-size: 0.9rem;
        flex: 1;
    }

        .detail-value strong {
            color: #f39c12;
        }

        .detail-value i {
            margin-right: 0.35rem;
        }

    .status-badge-detail {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .status-paid {
        background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
        color: #155724;
    }

    .status-pending {
        background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
        color: #856404;
    }

    .status-overdue {
        background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
        color: #721c24;
    }

    .status-inactive {
        background: #e9ecef;
        color: #6c757d;
    }

    .amount-box {
        text-align: center;
        padding: 1.5rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 10px;
        margin: 1rem 0;
    }

        .amount-box h3 {
            color: #27ae60;
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0;
        }

        .amount-box p {
            color: #7f8c8d;
            margin: 0.5rem 0 0 0;
            font-size: 0.9rem;
        }

    .text-muted-detail {
        color: #95a5a6;
        font-style: italic;
    }

    .btn-close-modal {
        background: #95a5a6;
        border: none;
        padding: 0.65rem 1.75rem;
        border-radius: 6px;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-close-modal:hover {
            background: #7f8c8d;
        }

</style>

<!-- Estado de la cuota -->
<div class="mb-3 text-center">
    @if (Model.IsActive)
    {
        @if (Model.PaymentStatus?.StatusName == "Pagado")
        {
            <span class="status-badge-detail status-paid">
                <i class="bi bi-check-circle-fill"></i>
                Cuota Pagada
            </span>
        }
        else if (diasVencimiento < 0)
        {
            <span class="status-badge-detail status-overdue">
                <i class="bi bi-exclamation-circle-fill"></i>
                Cuota Vencida
            </span>
        }
        else
        {
            <span class="status-badge-detail status-pending">
                <i class="bi bi-clock-fill"></i>
                Cuota Pendiente
            </span>
        }
    }
    else
    {
        <span class="status-badge-detail status-inactive">
            <i class="bi bi-dash-circle-fill"></i>
            Cuota Desactivada
        </span>
    }
</div>

<!-- Información General -->
<div class="details-section">
    <div class="details-section-title">
        <i class="bi bi-info-circle-fill"></i>
        Información General
    </div>

    <div class="detail-row">
        <div class="detail-label">Curso:</div>
        <div class="detail-value"><strong>@Model.Inscripcion?.CursoVacacional?.NombreCurso</strong></div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Estudiante:</div>
        <div class="detail-value">
            <i class="bi bi-person-fill"></i>
            <strong>@Model.Student?.NombreCompleto</strong>
            <br>
            <small class="text-muted-detail">DNI: @Model.Inscripcion?.Student?.DNI</small>
        </div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Apoderado:</div>
        <div class="detail-value">
            <i class="bi bi-person-heart"></i>
            @Model.Inscripcion?.LegalGuardian?.NombreCompleto
        </div>
    </div>
</div>

<!-- Período y Vencimiento -->
<div class="details-section">
    <div class="details-section-title">
        <i class="bi bi-calendar-month"></i>
        Período y Vencimiento
    </div>

    <div class="detail-row">
        <div class="detail-label">Período:</div>
        <div class="detail-value">
            <i class="bi bi-calendar"></i>
            <strong>@Model.Mes @Model.Anio</strong>
        </div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Fecha Vencimiento:</div>
        <div class="detail-value">
            <i class="bi bi-calendar-x"></i>
            @Model.FechaVencimiento.ToString("dd/MM/yyyy")
            @if (Model.PaymentStatus?.StatusName != "Pagado")
            {
                if (diasVencimiento < 0)
                {
                    <br>
                    <span class="badge" style="background: #e74c3c; color: white;">
                        Vencida hace @Math.Abs(diasVencimiento) días
                    </span>
                }
                else if (diasVencimiento <= 7)
                {
                    <br>
                    <span class="badge" style="background: #f39c12; color: white;">
                        Vence en @diasVencimiento días
                    </span>
                }
                else
                {
                    <br>
                    <span class="badge" style="background: #3498db; color: white;">
                        Faltan @diasVencimiento días
                    </span>
                }
            }
        </div>
    </div>
</div>

<!-- Información de Pago -->
<div class="details-section">
    <div class="details-section-title">
        <i class="bi bi-cash-coin"></i>
        Información de Pago
    </div>

    <div class="amount-box">
        <h3>S/ @Model.Monto.ToString("N2")</h3>
        <p>Monto de la Cuota</p>
    </div>

    <div class="detail-row">
        <div class="detail-label">Estado del Pago:</div>
        <div class="detail-value">
            @if (Model.PaymentStatus?.StatusName == "Pagado")
            {
                <span class="badge" style="background: linear-gradient(135deg, #27ae60 0%, #229954 100%); color: white; padding: 0.5rem 1rem; font-size: 0.9rem;">
                    <i class="bi bi-check-circle-fill"></i> Pagado
                </span>
            }
            else if (Model.PaymentStatus?.StatusName == "Vencido" || diasVencimiento < 0)
            {
                <span class="badge" style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); color: white; padding: 0.5rem 1rem; font-size: 0.9rem;">
                    <i class="bi bi-exclamation-circle-fill"></i> Vencido
                </span>
            }
            else
            {
                <span class="badge" style="background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%); color: white; padding: 0.5rem 1rem; font-size: 0.9rem;">
                    <i class="bi bi-clock-fill"></i> Pendiente
                </span>
            }
        </div>
    </div>
</div>

<!-- Información del Sistema -->
<div class="details-section">
    <div class="details-section-title">
        <i class="bi bi-gear-fill"></i>
        Información del Sistema
    </div>

    <div class="detail-row">
        <div class="detail-label">ID Cuota:</div>
        <div class="detail-value">@Model.QuotaVacacionalId</div>
    </div>

    <div class="detail-row">
        <div class="detail-label">ID Inscripción:</div>
        <div class="detail-value">@Model.InscripcionId</div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Estado:</div>
        <div class="detail-value">
            @if (Model.IsActive)
            {
                <span class="badge" style="background: #27ae60; color: white;">Activa</span>
            }
            else
            {
                <span class="badge" style="background: #95a5a6; color: white;">Desactivada</span>
            }
        </div>
    </div>
</div>

<!-- Botones -->
<div class="modal-footer">
    <button type="button" class="btn-close-modal" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Cerrar
    </button>
</div>