@model EduConectaPeru.Models.Matricula
@{ Layout = null; }

<style>
    .modal-header-custom {
        background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
        color: white;
        border: none;
        padding: 20px 30px;
        border-radius: 15px 15px 0 0;
    }
    .modal-header-custom h5 { margin: 0; font-weight: 600; font-size: 1.3rem; }
    .modal-header-custom .btn-close { filter: brightness(0) invert(1); }
    .form-label-custom { font-weight: 600; color: #495057; margin-bottom: 8px; }
    .form-control-custom, .form-select-custom { border: 2px solid #e0e0e0; border-radius: 8px; padding: 10px 15px; }
    .btn-submit-custom { background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%); border: none; padding: 12px 30px; border-radius: 8px; font-weight: 600; color: white; }
    .btn-cancel-custom { background: #6c757d; border: none; padding: 12px 30px; border-radius: 8px; font-weight: 600; color: white; }
</style>

<form method="post" action="@Url.Action("Edit", new { id = Model.MatriculaId })" id="formEdit">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="MatriculaId" />
    <input type="hidden" asp-for="FechaMatricula" />
    <input type="hidden" asp-for="IsActive" />
    
    <div class="modal-header-custom">
        <h5><i class="bi bi-pencil-square"></i> Editar Matrícula #@Model.MatriculaId</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    
    <div class="modal-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label-custom">Estudiante</label>
                <select asp-for="StudentId" class="form-select form-select-custom" asp-items="ViewBag.Estudiantes" id="studentSelectEdit"></select>
            </div>

            <div class="col-md-6">
                <label class="form-label-custom">Apoderado</label>
                <select asp-for="LegalGuardianId" class="form-select form-select-custom" asp-items="ViewBag.Apoderados" id="guardianSelectEdit"></select>
                <small class="text-muted">Se actualiza al cambiar estudiante</small>
            </div>

            <div class="col-md-6">
                <label class="form-label-custom">Grado/Sección</label>
                <select asp-for="GradoSeccionId" class="form-select form-select-custom" asp-items="ViewBag.GradoSecciones"></select>
            </div>

            <div class="col-md-6">
                <label class="form-label-custom">Año Escolar</label>
                <input asp-for="AnioEscolar" class="form-control form-control-custom" type="number" />
            </div>

            <div class="col-md-6">
                <label class="form-label-custom">Monto (S/)</label>
                <input asp-for="MontoMatricula" class="form-control form-control-custom" type="number" step="0.01" />
            </div>

            <div class="col-md-6">
                <label class="form-label-custom">Estado</label>
                <select asp-for="Estado" class="form-select form-select-custom">
                    <option value="Activa">Activa</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Cancelada">Cancelada</option>
                </select>
            </div>
        </div>
    </div>

    <div class="modal-footer border-0 px-4 pb-4">
        <button type="button" class="btn btn-cancel-custom" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-submit-custom">Actualizar</button>
    </div>
</form>

<script>
$('#studentSelectEdit').change(function() {
    var studentId = $(this).val();
    if (studentId) {
        $.get('@Url.Action("GetLegalGuardianByStudent")', { studentId: studentId }, function(data) {
            if (data.success && data.legalGuardianId) {
                $('#guardianSelectEdit').val(data.legalGuardianId);
            }
        });
    }
});

$('#formEdit').submit(function(e) {
    e.preventDefault();
    $.post($(this).attr('action'), $(this).serialize(), function() {
        location.reload();
    }).fail(function(xhr) {
        if (xhr.status === 400) $('#editModalContent').html(xhr.responseText);
    });
});
</script>
